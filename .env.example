APP_ENV=local
APP_PORT=8000
LOG_LEVEL=INFO

# express.ms / BotX
BOT_ID=
BOT_SECRET_KEY=
BOTX_BASE_URL=
BOTX_PROTO_VERSION=
BOT_ADMIN_HUIDS=

# Active Directory / LDAPS
LDAP_HOST=
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_BIND_USER=
LDAP_BIND_PASSWORD=
LDAP_BIND_PASSWORD_FILE=
LDAP_BASE_DN=
LDAP_INCLUDED_OUS=
LDAP_EXCLUDED_OUS=
LDAP_CA_CERT_FILE=
LDAP_CONNECT_TIMEOUT_SECONDS=10
LDAP_READ_TIMEOUT_SECONDS=15

# Search and cache
SEARCH_LIMIT=5
CACHE_DB_PATH=/data/cache.sqlite3
CACHE_TTL_SECONDS=86400
